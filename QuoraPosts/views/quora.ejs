<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!--
    
    post -username
    content


    1.view
    2.individual
    3.edit
    4.delete

    
     -->
    <h1>Quora Posts</h1>

<% for(post of posts){ %>
<div class="post">

    <h1 class="user">@ <%= post.username %></h1>
        <h2 class="content"><%= post.content %></h2>
        
    </div>
    <a href="http://localhost:8080/quoraposts/<%=post.id%>">See in detail</a>
    <a href="http://localhost:8080/quoraposts/<%=post.id%>/edit">Edit Post</a>


    <form method="post" action="http://localhost:8080/quoraposts/<%=post.id%>?_method=DELETE">
<button>Delete post</button>
    </form>


<% } %>


