<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
</head>
<body>

    <form method="post" action="/quoraposts/<%=post.id%>?_method=PATCH">

   <h1>edit your post</h1> 
   <p> Post id :<%= post.id%></p>
      <p> Post username :<%= post.username%></p>

   <p></p>

   <textarea rows="10" columns="20" name="content">
 <%= post.content%>

   </textarea>

   <button>Submit</button>
       </form>

</body>
</html>